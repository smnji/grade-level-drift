# Secrets — never commit
.env
.env.local
*.key
*.pem

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/

# Notebooks
.ipynb_checkpoints/

# Data — see data/README.md for the full policy.
# raw/, generated/ are regenerable and gitignored. interim/ is "commit
# selectively" — contents ignored by default, allow .gitkeep so the dir
# is tracked. processed/ and results/ ARE committable (sample frames,
# run manifests, aggregated results, per-run scores).
data/raw/
data/generated/
data/interim/*
!data/interim/.gitkeep

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
*.swo
.claude/
