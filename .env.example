# Copy to .env and fill in. .env is gitignored; never commit secrets.

# Learning Commons Knowledge Graph API (private beta as of 2026-05)
# Request a key from the Learning Commons Platform: https://platform.learningcommons.org
LC_API_KEY=
LC_API_BASE=https://api.learningcommons.org/knowledge-graph/v0

# Anthropic — used as the primary instruction generator
ANTHROPIC_API_KEY=

# Evaluator backends — LC's literacy evaluators call OpenAI and Gemini
# under the hood. Both keys are required to run the evaluator pipeline.
OPENAI_API_KEY=
GOOGLE_API_KEY=
