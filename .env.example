# Copy to .env and fill in. .env is gitignored; never commit secrets.

# Learning Commons Knowledge Graph API (private beta as of 2026-05)
# Used to pull standards data only. Evaluation is fully deterministic and
# does not call any LC API. Request a key from the LC Platform:
#   https://platform.learningcommons.org
LC_API_KEY=
LC_API_BASE=https://api.learningcommons.org/knowledge-graph/v0

# OpenAI — used for generation (the v0 instruction generator) and for the
# rewriter that produces simplified wording variants of each standard.
# This is the only LLM key v0 needs; evaluation is deterministic
# (textstat + spaCy + word-list lookups), no API calls.
OPENAI_API_KEY=
